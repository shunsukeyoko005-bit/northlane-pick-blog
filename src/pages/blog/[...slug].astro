---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { coverForSlug } from '../../lib/covers';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const clusterLabels: Record<string, string> = {
  'sunscreen-spf': 'Sunscreen & SPF',
  'skincare-routine': 'Skincare Routine',
};

const clusterLabel = post.data.cluster
  ? (clusterLabels[post.data.cluster] ?? post.data.cluster)
  : null;

const formattedDate = post.data.created
  ? new Date(`${post.data.created}T12:00:00`).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

const coverImage = coverForSlug(post.id, post.data.cover_image);
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={coverImage}
  narrow
>
  <header class="article-hero">
    <div class="article-hero__cover">
      <img src={coverImage} alt="" width="1200" height="630" decoding="async" />
    </div>
    <div class="article-hero__content">
      <div class="article-hero__meta">
        {clusterLabel && <span class="cluster-pill">{clusterLabel}</span>}
        {
          formattedDate && (
            <time class="post-card__date" datetime={post.data.created}>
              {formattedDate}
            </time>
          )
        }
      </div>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
    </div>
  </header>
  <article class="article-body">
    <Content />
  </article>
</Base>
